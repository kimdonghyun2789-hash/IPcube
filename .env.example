# IP3 environment variables (optional)
#
# API keys can be set here OR entered in the in-app Settings screen.
# Values stored in the Settings screen take priority over these.

# KIPRISPlus API key (patent search / bibliography / claims / drawings)
KIPRISPLUS_API_KEY=

# AI provider for the comparison analysis step
# One of: Gemini | OpenAI | Anthropic | Local/Other | 사용 안 함
AI_PROVIDER=

# AI API key for the selected provider
AI_API_KEY=
